# ============================================================================
# UMBRAXON KYA-Hub — .env.example
# ----------------------------------------------------------------------------
# This file is committed to the repo and lists the env keys the hub reads.
# The real `.env` lives at /root/kya-hub/.env (chmod 600) and is NEVER
# committed. Copy this file with `cp .env.example .env` then fill in the
# values.
#
# Sections only show the env vars introduced or revised by the
# Cloudflare R2 + Alby unlock refactor. Existing keys (DB_*, BTCPAY_*, etc.)
# are documented in UMBRAXON.md.
# ============================================================================

# ---------------------------------------------------------------------------
# Off-site backup destination (Workstream A)
# ---------------------------------------------------------------------------
# Used by:
#   - scripts/backup-channel-state.sh   (Lightning channel state, hourly cron)
#   - scripts/backup-database.sh        (PostgreSQL daily backup)
#   - scripts/dac8-export.js            (DAC8 daily accounting export)
#
# Client-side encryption (BACKUP_PASSPHRASE, 64-hex / 32 bytes) is applied
# BEFORE upload, regardless of the destination provider. Lose the passphrase
# and your backups become unrecoverable — store it offline.
#
# Generate one with:
#   node -e 'console.log(require("crypto").randomBytes(32).toString("hex"))'
BACKUP_PASSPHRASE=

# --- Primary destination: S3-compatible (Cloudflare R2 / AWS / MinIO / ...) ---
# Cloudflare R2 endpoint (preferred). Get from:
#   https://dash.cloudflare.com → R2 → Manage R2 API Tokens → "Use Endpoint"
#   Standard:          https://<ACCOUNT_ID>.r2.cloudflarestorage.com
#   EU jurisdiction:   https://<ACCOUNT_ID>.eu.r2.cloudflarestorage.com
BACKUP_S3_ENDPOINT=

# "auto" is correct for R2. Use "us-east-1" / "eu-central-1" etc. for AWS S3,
# the configured region for MinIO/DO Spaces.
BACKUP_S3_REGION=auto

# R2 token: "Create API Token" → "Object Read & Write" → scoped to your bucket.
# The token shows TWO values — paste Access Key ID into the first var,
# Secret Access Key into the second.
BACKUP_S3_ACCESS_KEY_ID=
BACKUP_S3_SECRET_ACCESS_KEY=

# Bucket name (must already exist; create one private + lifecycle-policied
# in the R2 dashboard before pasting credentials).
BACKUP_S3_BUCKET=

# Optional key prefix (default `kyahub/`). All artifacts land under
#   <prefix>{lightning_channel,db,dac8}/...
BACKUP_S3_PREFIX=kyahub/

# --- Legacy fallback: Backblaze B2 native CLI (only used when BACKUP_S3_* unset) ---
# Kept for backwards compatibility. If both sets are populated, BACKUP_S3_* wins.
B2_KEY_ID=
B2_APP_KEY=
B2_BUCKET=
B2_S3_ENDPOINT=

# Local hot-tier (always written, regardless of off-site provider).
BACKUP_LOCAL_DIR=/root/backups
BACKUP_HOT_RETENTION_DAYS=30
BACKUP_COLD_RETENTION_DAYS=365

# Tier pricing fallback (used when tier_pricing has no active row for that tier).
# Operator policy: BASIC 10k, ELITE 80k (Strategic Sprint §31 D).
TIER_BASIC_SATS=10000
TIER_ELITE_SATS=80000

# One-time R2 lifecycle policy (set in Cloudflare dashboard, not here):
#   1. Bucket → Settings → Object Lifecycle Rules → Add Rule
#   2. Recommended:
#      - Delete after 90 days  for kyahub/lightning_channel/  (high churn)
#      - Infrequent Access after 30 days for kyahub/db/ + kyahub/dac8/
#   3. Optional: enable bucket versioning + 7-day version retention to
#      protect against accidental delete-by-the-script.

# ---------------------------------------------------------------------------
# Alby Hub HTTP-API unlock password (Workstream B)
# ---------------------------------------------------------------------------
# Used by:
#   - scripts/lightning-liquidity-monitor.js
#
# The monitor POSTs this to {ALBY_HUB_URL}/api/login to obtain a session
# cookie / JWT, then calls /api/channels for full inbound + outbound state.
#
# Password sources (first-match wins):
#   1. ALBY_UNLOCK_PASSWORD env var (preferred — set here)
#   2. File at ALBY_UNLOCK_PASSWORD_FILE, default /root/kya-hub/.secrets/alby-unlock.txt
#      (perms must be 0600, otherwise the monitor refuses to read it)
#
# Without either, the monitor falls back to NWC (outbound-only) and emits
# ONE Telegram warning per process lifetime — subsequent cycles stay silent.
ALBY_UNLOCK_PASSWORD=
ALBY_HUB_URL=http://127.0.0.1:8080
ALBY_UNLOCK_PASSWORD_FILE=/root/kya-hub/.secrets/alby-unlock.txt

# Threshold tuning (defaults shown):
#   - WARN  if inbound < INBOUND_RATIO_PCT % of outbound (default 25)
#   - CRIT  if inbound < MIN_INBOUND_SATS (default 10000)
# Legacy absolute thresholds (kept for backwards compatibility):
LIQUIDITY_INBOUND_RATIO_PCT=25
LIQUIDITY_MIN_INBOUND_SATS=10000
LIQUIDITY_WARN_SATS=500000
LIQUIDITY_CRITICAL_SATS=200000
LIQUIDITY_HTTP_TIMEOUT_MS=5000

# ELITE public listing liveness (paid heartbeat — cert stays valid; /api/whitelist/elite filters by status)
# LISTED → overdue → GRACE (still recoverable with heartbeat fee) → grace expires → DELISTED (reactivation fee or 1× free/year)
ELITE_LISTING_HEARTBEAT_DAYS=30
ELITE_LISTING_GRACE_DAYS=30
ELITE_LISTING_HEARTBEAT_SATS=150
ELITE_LISTING_REACTIVATION_SATS=5000

# ---------------------------------------------------------------------------
# PDF Invoice generator (Strategic Sprint §31 C)
# ---------------------------------------------------------------------------
# Header for tax invoices issued on InvoiceSettled (BTCPay) or Alby-NWC settled
# events. All values are operator-supplied; leave VAT_ID blank if not VAT-registered.
# Mirror to R2 happens via the same BACKUP_S3_* credentials used elsewhere.

INVOICE_SELLER_NAME=
INVOICE_SELLER_ADDRESS=
INVOICE_SELLER_TAX_ID=
INVOICE_SELLER_VAT_ID=
INVOICE_SELLER_IBAN=
INVOICE_SELLER_EMAIL=
INVOICE_SELLER_WEBSITE=https://umbraxon.xyz
INVOICE_SELLER_LOGO_PATH=
INVOICE_NUMBER_PREFIX=UMX-2026-
INVOICE_CURRENCY=EUR

# Public verifier base URL embedded in the QR code on each PDF.
# Receivers can scan the QR to fetch the live cert state at:
#   <INVOICE_VERIFIER_BASE>/<KYA_ID>
INVOICE_VERIFIER_BASE=https://umbraxon.xyz/api/cert

# Local disk root for issued PDFs. Generator writes to
#   $INVOICE_LOCAL_DIR/<YYYY>/<MM>/UMX-<ts>-<KYA_ID>.pdf
INVOICE_LOCAL_DIR=/root/kya-hub/invoices

# If set, generator will also push the PDF to s3://$BACKUP_S3_BUCKET/kyahub/invoices/...
# Disable by setting to "false".
INVOICE_PUSH_TO_R2=true

# BTC→EUR conversion source: 'coingecko' (default; cached 5 min in-process)
# or 'fixed' with a manual rate via INVOICE_BTC_RATE_EUR.
INVOICE_FX_PROVIDER=coingecko
INVOICE_BTC_RATE_EUR=

# ---------------------------------------------------------------------------
# Sentry (P2) — opt-in exception tracking
# ---------------------------------------------------------------------------
# Disabled by default. When set, server.js wires Sentry request + error handlers.
#
# Security defaults:
# - sendDefaultPii=false
# - request body/cookies scrubbed; auth headers redacted
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=
# Keep 0 in prod unless you explicitly want traces.
SENTRY_TRACES_SAMPLE_RATE=0

# ---------------------------------------------------------------------------
# Watchtower monitoring (P2) — opt-in log-based health signal
# ---------------------------------------------------------------------------
# This does NOT configure a watchtower; it only alerts if the connection signal
# disappears from Alby Hub logs.
WATCHTOWER_MONITOR_ENABLED=false
WATCHTOWER_MONITOR_WINDOW_MIN=30
WATCHTOWER_MONITOR_LOG_PATH=/root/.pm2/logs/alby-hub-out.log
WATCHTOWER_MONITOR_REGEX=watchtower

# ---------------------------------------------------------------------------
# Proof-of-Work (Phase 2.2) — /api/pay, /api/register/initiate
# ---------------------------------------------------------------------------
# Full reference: UMBRAXON.md §16.7. Omit these to use code defaults.
POW_ENABLED=true
POW_DEFAULT_DIFFICULTY=18
# Optional: lower default difficulty for registration challenges only (weak / BASIC-tier clients).
# If unset, register uses the same value as POW_DEFAULT_DIFFICULTY.
# POW_REGISTER_DIFFICULTY=16
POW_TTL_SEC=300
POW_REQUIRED_FOR=pay,register
# Optional: max iterations for lib/pow.solve() helper (tests/SDK). Production clients should loop until success.
# POW_SOLVE_MAX_ITERATIONS=50000000

# ---------------------------------------------------------------------------
# Auth challenge (challenge-response) — base TTL + adaptive 403-spike extension
# ---------------------------------------------------------------------------
# Base TTL for /api/auth/challenge nonces (used by register/initiate, action signing).
# Default 300s (5 min). Lower = stricter anti-replay, higher = friendlier to slow clients.
# AUTH_CHALLENGE_TTL_SEC=300
#
# Adaptive 403-spike protection: when the hub returns many 403 in a short window
# (mass-suspended agents retrying, bulk bad-sig, enforcement waves) new auth
# challenges are issued with a longer TTL so honest clients can still finish
# their flow before their nonce expires. See lib/http-403-tracker.js.
AUTH_CHALLENGE_403_SPIKE_WINDOW_MIN=10
AUTH_CHALLENGE_403_SPIKE_THRESHOLD=30
AUTH_CHALLENGE_403_SPIKE_TTL_MULTIPLIER=2
# Optional: when entering spike mode, also extend already-issued (unused, not yet expired)
# challenges by the difference between the new and base TTL. Off by default — running
# the UPDATE under sustained load costs DB writes.
# AUTH_CHALLENGE_EXTEND_OPEN_ON_SPIKE=true

# ---------------------------------------------------------------------------
# Public cache knobs (Phase 4/5) — safe defaults
# ---------------------------------------------------------------------------
# TTL for public whitelist endpoints (ms)
WHITELIST_CACHE_TTL_MS=60000
# TTL for public CRL endpoints (ms)
CRL_CACHE_TTL_MS=60000

# ---------------------------------------------------------------------------
# Bot Developer Portal — canonical base for bots.umbraxon.xyz → 301 redirect
# ---------------------------------------------------------------------------
# Optional. Default: https://www.umbraxon.xyz/bots (no trailing slash).
# BOTS_PORTAL_PUBLIC_BASE=https://www.umbraxon.xyz/bots
# By default /bots/ is served for any Host (avoids broken /bots/ behind mis-set proxy Host headers).
# Set to 1 to restrict /bots/ to MAIN_WEB_HOSTS plus BOTS_PORTAL_ALLOWED_HOSTS only.
# BOTS_PORTAL_REQUIRE_MAIN_HOST=1
# Comma-separated extra hostnames when REQUIRE_MAIN_HOST=1 (e.g. staging.example.com).
# BOTS_PORTAL_ALLOWED_HOSTS=staging.umbraxon.xyz
