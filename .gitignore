# =========================================================================
# UMBRAXON KYA-Hub — .gitignore
# Rule of thumb: source + runbooks + tests = tracked.
# Operator state (env, wallets, logs, backups, exports) = ignored.
# =========================================================================

# --- Secrets / local env -------------------------------------------------
.env
.env.*
# template MUST ship in the repo:
!.env.example
*.env.bak.*
*.env.backup.*
.secrets/
.backup/

# --- Wallet artifacts (public or not) should not be committed -----------
.cold-wallet-public.json

# --- Generated media artifacts ------------------------------------------
qr-*.png
.invoice-qr-*.png

# --- Alby Hub runtime artifacts / binaries (operator-installed) ---------
albyhub/workdir/
albyhub/bin/
albyhub/lib/
albyhub/*.tar.*
albyhub/*.tar.bz2
albyhub/*.tgz
albyhub/*.zip
albyhub/*.so
albyhub/*.db
albyhub/*.db-*
albyhub/*.sqlite

# --- Node ----------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Runtime logs / exports / local data --------------------------------
*.log
output.log
server.log
*.log.*
logs/
tmp/
backups/
exports/
invoices/
data-exports/
.dac8-rate-cache/
.tmp-ssh/
.tmp-scout-posted.json
*.pid

# local npm auth files (may contain tokens)
.npmrc
**/.npmrc

# --- Python (monitoring dashboard local venv + caches) ------------------
monitoring/.venv/
agents/umbraxon-pr-agent/.venv/
**/__pycache__/
*.pyc

# --- OS / editor ---------------------------------------------------------
.DS_Store
.idea/
.vscode/

# --- Local release bundles (git archive / hand-off tarballs) ------------
dist/

# --- Personal / off-project (not UMBRAXON KYA-Hub) -----------------------
OFFPROJECT-battery-passport-starter/

# --- Local one-off analysis uploads (not part of hub) ----------------------
upload-energocom/
