# KYA Hub (M2M)
KYA_HUB_BASE_URL=https://www.umbraxon.xyz
KYA_AGENT_NAME=UMBRAXON-PR-AMBASSADOR
KYA_AGENT_VERSION=1.0.0
KYA_TIER=BASIC
KYA_PRIVKEY_FILE=./secrets/bot.key
KYA_LIGHTNING_NODE_ID=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
KYA_ID=
KYA_REGISTRATION_ID=
KYA_CERT_FILE=./secrets/certificate.json
KYA_REGISTER_WAIT=true
# KYA Hub reputation liveness (run_cycle); set false to disable after testing
PR_KYA_HEARTBEAT=true
# Optional richer weekly report:
# KYA_ADMIN_API_KEY=

# LLM (promote, report, support)
LLM_PROVIDER=openai
LLM_API_KEY=
# Or keep LLM_API_KEY empty and store key in a file (chmod 600):
# LLM_API_KEY_FILE=/root/kya-hub/.secrets/openai-api-key.txt
LLM_MODEL=gpt-4o-mini

# Moltbook — https://www.moltbook.com/skill.md
MOLTBOOK_API_KEY=
MOLTBOOK_BASE_URL=https://www.moltbook.com
MOLTBOOK_AGENT_NAME=umbraxon-pr-ambassador
MOLTBOOK_AUTO_REPLY=true
MOLTBOOK_REPLY_LANGUAGE=en
# Moltbook posts: English only (enforced in pr/crosspost.py). Mastodon queue may use SK.
PR_POST_LANGUAGE=en
MOLTBOOK_REPLY_ON_OWN_POSTS=true
MOLTBOOK_REPLY_ON_FEED=true
MOLTBOOK_MAX_REPLIES_PER_RUN=2
MOLTBOOK_MIN_HOURS_BETWEEN_COMMENTS=2

# PR behaviour (Phase A)
PR_DRY_RUN=true
PR_MAX_POSTS_PER_RUN=1
PR_MIN_HOURS_BETWEEN_POSTS=24
PR_MIN_CONTENT_CHARS=80
PR_MAX_LINKS_PER_POST=3
PR_HUB_URL_REQUIRED=true
PR_PUBLISH_PLATFORMS=moltbook
# After Moltbook claim + keys: moltbook,nostr,discord,x,telegram

# Phase B — cross-post (optional)
# NOSTR_PRIVATE_KEY=nsec1...
# NOSTR_PRIVATE_KEY_FILE=./secrets/nostr-nsec.txt
# NOSTR_RELAYS=wss://relay.damus.io,wss://nos.lol
# NOSTR_MIN_HOURS_BETWEEN_POSTS=48
# Profile: python3 main.py nostr-profile  (bio includes Plug-in API + FAQ §I link)
# Notes (Mon/Wed/Fri cron): python3 main.py nostr-post  (rotation incl. platform_integrator; Wed → platform)
# X_API_KEY= / X_API_SECRET= / X_ACCESS_TOKEN= / X_ACCESS_TOKEN_SECRET=
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
# TELEGRAM_BOT_TOKEN= / TELEGRAM_NOTIFY_CHAT_ID=
# TELEGRAM_MONITOR_KEYWORDS=agent identity,m2m payments,lightning agent
# TELEGRAM_AUTO_REPLY=false

# Phase C — weekly report
REPORT_AUTO_PUBLISH=false

# Phase D — GitHub leads (dry-run saves messages to logs/pr-agent/leads/)
GITHUB_TOKEN=
GITHUB_SEARCH_QUERY="ai agent autonomous language:python stars:>5"
GITHUB_MAX_LEADS_PER_RUN=3
GITHUB_OUTREACH_DRY_RUN=true

AUTO_PAY_REGISTRATION=false
NWC_PAY_URI_FILE=/root/kya-hub/.secrets/alby-nwc.txt
